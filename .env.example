# === APP ===
APP_NAME="Rattlescorpion Omni"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Kolkata
APP_LOCALE=en_IN

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# === DATABASE ===
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pfre_omni
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
FILESYSTEM_DISK=local
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

# === REDIS ===
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file

# === WHATSAPP BUSINESS API ===
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# === GST / IRP (e-Invoice) ===
GSTN_CLIENT_ID=
GSTN_CLIENT_SECRET=
GSTN_GSTIN=
IRP_API_URL=https://einvoice1.gst.gov.in
IRP_USERNAME=
IRP_PASSWORD=

# === AADHAAR eSIGN ===
AADHAAR_ESIGN_API_URL=
AADHAAR_ESIGN_ASP_ID=
AADHAAR_ESIGN_ASP_SECRET=

# === CIBIL ===
CIBIL_MEMBER_ID=
CIBIL_PASSWORD=
CIBIL_API_URL=

# === GOOGLE MAPS ===
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_GEOCODING_KEY=

# === SMS (msg91 / Twilio) ===
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=
MSG91_SENDER_ID=PFROMNI
MSG91_TEMPLATE_ID=

# === MAIL ===
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="propertyfinderre@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"

# === STORAGE ===
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# === QUEUE / HORIZON ===
HORIZON_PREFIX=pfre_omni:

# === LOGGING ===
LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# === RERA ===
RERA_MH_API_URL=https://maharera.mahaonline.gov.in
RERA_API_KEY=

# === OTA CHANNEL MANAGER ===
OTA_PROVIDER=
OTA_API_KEY=
OTA_API_SECRET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
