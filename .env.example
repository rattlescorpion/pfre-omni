# ============================================================
# PFRE-OMNI — Property Finder Real Estate Omni Platform
# .env.example — copy to .env and fill in values
# ============================================================

# === APP ===
APP_NAME="PFRE Omni"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Kolkata
APP_LOCALE=en_IN
APP_CIPHER=AES-256-CBC
INTERNAL_API_SECRET=

# === LOGGING ===
LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# === DATABASE ===
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pfre_omni
DB_USERNAME=root
DB_PASSWORD=

# === CACHE / SESSION / QUEUE ===
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis
BROADCAST_DRIVER=pusher
FILESYSTEM_DISK=local

# === REDIS ===
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_QUEUE_DB=3

# === HORIZON ===
HORIZON_PREFIX=pfre_omni:
HORIZON_BALANCE=auto
HORIZON_MIN_PROCESSES=1
HORIZON_MAX_PROCESSES=10
HORIZON_MEMORY_LIMIT=128

# === TELESCOPE ===
TELESCOPE_ENABLED=true
TELESCOPE_PATH=telescope

# === MAIL ===
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@pfre-omni.com"
MAIL_FROM_NAME="${APP_NAME}"

# === STORAGE (S3 / Wasabi) ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# === SEARCH (Meilisearch via Laravel Scout) ===
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

# === RAZORPAY ===
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# === WHATSAPP BUSINESS API (Meta Cloud API) ===
WHATSAPP_API_URL=https://graph.facebook.com/v21.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# === SMS (MSG91) ===
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=
MSG91_SENDER_ID=PFROMNI
MSG91_TEMPLATE_ID=

# === PUSH NOTIFICATIONS (FCM) ===
FCM_SERVER_KEY=
FCM_SENDER_ID=

# === PUSHER / BROADCASTING ===
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=ap2

# === GST / IRP (e-Invoice) ===
GSTN_CLIENT_ID=
GSTN_CLIENT_SECRET=
GSTN_GSTIN=
IRP_API_URL=https://einvoice1.gst.gov.in
IRP_USERNAME=
IRP_PASSWORD=

# === RERA / MahaRERA ===
RERA_MH_API_URL=https://maharera.mahaonline.gov.in
RERA_API_KEY=

# === AADHAAR eSIGN ===
AADHAAR_ESIGN_API_URL=
AADHAAR_ESIGN_ASP_ID=
AADHAAR_ESIGN_ASP_SECRET=

# === CIBIL ===
CIBIL_MEMBER_ID=
CIBIL_PASSWORD=
CIBIL_API_URL=

# === GOOGLE MAPS ===
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_GEOCODING_KEY=

# === INDIAN COMPLIANCE ===
COMPANY_PAN=
TRACES_USER_ID=
TRACES_PASSWORD=
TRACES_TAN=
MCA_API_URL=https://www.mca.gov.in
MCA_API_KEY=
BBPS_AGENT_ID=
BBPS_API_KEY=

# === OTA CHANNEL MANAGER ===
OTA_PROVIDER=
OTA_API_KEY=
OTA_API_SECRET=

# === VITE (Frontend) ===
VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"