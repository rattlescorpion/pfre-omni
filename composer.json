{
    "name": "propertyfinder/pfre-omni",
    "type": "project",
    "description": "Property Finder Real Estate — Omni Enterprise Platform v6",
    "keywords": ["laravel", "real-estate", "erp", "crm", "pms"],
    "license": "proprietary",
    "require": {
        "php": "^8.4",

        "laravel/framework": "^10.50.2",
        "laravel/sanctum": "^3.3.3",
        "laravel/tinker": "^2.11.1",

        "guzzlehttp/guzzle": "^7.10.0",
        "predis/predis": "^2.4.1",

        "spatie/laravel-permission": "^6.25.0",
        "spatie/laravel-activitylog": "^4.12.3",
        "spatie/laravel-backup": "^8.8.2",
        "spatie/laravel-medialibrary": "^11.21.0",
        "spatie/laravel-query-builder": "^5.8.1",
        "spatie/laravel-data": "^4.21.0",
        "spatie/laravel-sluggable": "^3.8.1",

        "barryvdh/laravel-dompdf": "^2.2.0",
        "maatwebsite/excel": "^3.1.68",
        "phpoffice/phpspreadsheet": "^1.30.3",
        "intervention/image": "^3.11.7",
        "intervention/image-laravel": "^1.5.9",

        "pragmarx/google2fa-laravel": "^2.3.1",
        "pragmarx/google2fa-qrcode": "^3.0.1",
        "simplesoftwareio/simple-qrcode": "^4.2.0",
        "bacon/bacon-qr-code": "^2.0.8",

        "league/flysystem-aws-s3-v3": "^3.32.0",
        "league/flysystem-sftp-v3": "^3.33.0",
        "league/csv": "^9.28.0",
        "league/oauth2-server": "^8.5.5",

        "darkaonline/l5-swagger": "^8.6.5",

        "aws/aws-sdk-php": "^3.379.0",

        "paragonie/constant_time_encoding": "^2.8.2",
        "paragonie/random_compat": "^2.0.21",

        "laravel/horizon": "^5.45.6",
        "laravel/telescope": "^4.17.6",
        "laravel/scout": "^10.25.0",

        "nnjeim/world": "^1.1.38",

        "propaganistas/laravel-phone": "^5.3.6",
        "webpatser/laravel-uuid": "^4.0.2",

        "knplabs/knp-snappy": "^1.6.0",

        "torann/geoip": "^3.0.10",

        "pusher/pusher-php-server": "^7.2.7"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24.1",
        "laravel/pint": "^1.29.0",
        "laravel/sail": "^1.57.0",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^7.12.0",
        "phpunit/phpunit": "^10.5.63",
        "spatie/laravel-ignition": "^2.9.1",
        "brianium/paratest": "^7.4.9",
        "pestphp/pest": "^2.36.1",
        "pestphp/pest-plugin-laravel": "^2.4.0",
        "phpstan/phpstan": "^1.12.33",
        "larastan/larastan": "^2.11.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php artisan storage:link --ansi"
        ],
        "lint": "pint",
        "test": "phpunit --testdox",
        "test-parallel": "paratest --processes=4",
        "analyse": "phpstan analyse --memory-limit=2G"
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/telescope"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "platform-check": false,
        "platform": {
            "php": "8.4.0",
            "ext-pcntl": "8.4.0",
            "ext-posix": "8.4.0"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}