{
    "name": "propertyfinder/pfre-omni",
    "type": "project",
    "description": "Property Finder Real Estate — Omni Enterprise Platform v6",
    "keywords": ["laravel", "real-estate", "erp", "crm", "pms"],
    "license": "proprietary",
    "require": {
        "php": "^8.2",

        "laravel/framework": "^10.48",
        "laravel/sanctum": "^3.3",
        "laravel/tinker": "^2.9",

        "guzzlehttp/guzzle": "^7.8",
        "predis/predis": "^2.2",

        "spatie/laravel-permission": "^6.3",
        "spatie/laravel-activitylog": "^4.8",
        "spatie/laravel-backup": "^8.5",
        "spatie/laravel-medialibrary": "^11.4",
        "spatie/laravel-query-builder": "^5.7",
        "spatie/laravel-data": "^4.6",
        "spatie/laravel-sluggable": "^3.5",

        "barryvdh/laravel-dompdf": "^2.2",
        "maatwebsite/excel": "^3.1",
        "phpoffice/phpspreadsheet": "^2.2",
        "intervention/image": "^3.7",
        "intervention/image-laravel": "^1.3",

        "pragmarx/google2fa-laravel": "^2.2",
        "pragmarx/google2fa-qrcode": "^3.0",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "bacon/bacon-qr-code": "^2.0",

        "league/flysystem-aws-s3-v3": "^3.0",
        "league/flysystem-sftp-v3": "^3.0",
        "league/csv": "^9.16",
        "league/oauth2-server": "^8.5",

        "darkaonline/l5-swagger": "^8.6",

        "aws/aws-sdk-php": "^3.296",

        "paragonie/constant_time_encoding": "^2.6",
        "paragonie/random_compat": "^2.0",

        "laravel/horizon": "^5.24",
        "laravel/telescope": "^5.0",
        "laravel/scout": "^10.8",

        "nnjeim/world": "^1.1",

        "propaganistas/laravel-phone": "^5.2",
        "webpatser/laravel-uuid": "^4.0",

        "knplabs/knp-snappy": "^1.4",

        "torann/geoip": "^3.0",

        "fruitcake/laravel-cors": "^3.0",

        "pusher/pusher-php-server": "^7.2"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^7.10",
        "phpunit/phpunit": "^10.5",
        "spatie/laravel-ignition": "^2.4",
        "brianium/paratest": "^7.3",
        "pestphp/pest": "^2.34",
        "pestphp/pest-plugin-laravel": "^2.3",
        "phpstan/phpstan": "^1.10",
        "larastan/larastan": "^2.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php artisan storage:link --ansi"
        ],
        "lint": "pint",
        "test": "phpunit --testdox",
        "test-parallel": "paratest --processes=4",
        "analyse": "phpstan analyse --memory-limit=2G"
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/telescope"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}